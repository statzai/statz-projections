# Destination DB (where projections are written)
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# Source DB (where raw fixture/stats data is read from)
SOURCE_DB_HOST=
SOURCE_DB_PORT=3306
SOURCE_DB_USER=
SOURCE_DB_PASSWORD=
SOURCE_DB_NAME=

# Local DB (used inside Docker for container-internal connections)
LOCAL_DB_HOST=127.0.0.1
LOCAL_DB_PORT=3306
LOCAL_DB_USER=
LOCAL_DB_PASSWORD=
LOCAL_DB_NAME=

# How many days ahead to project fixtures for
PROJECTION_DAYS=5

# Callback URL for status updates to the Laravel app
STATZ_CALLBACK_URL=https://statz.ai/api/internal/projections/status

# Shared secret used in the X-Projections-Secret header on callbacks
PROJECTIONS_API_SECRET=
