# Destination DB (where projections are written)
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# Source DB (where raw fixture/stats data is read from)
SOURCE_DB_HOST=
SOURCE_DB_PORT=3306
SOURCE_DB_USER=
SOURCE_DB_PASSWORD=
SOURCE_DB_NAME=

# Local DB (used inside Docker for container-internal connections)
LOCAL_DB_HOST=127.0.0.1
LOCAL_DB_PORT=3306
LOCAL_DB_USER=
LOCAL_DB_PASSWORD=
LOCAL_DB_NAME=

# How many days ahead to project fixtures for
PROJECTION_DAYS=5

# (Removed 2026-04-30) STATZ_CALLBACK_URL / PROJECTIONS_API_SECRET were
# used by the legacy HTTP-callback flow that pushed projection status
# back to Laravel. Replaced 2026-04-22 (statz 79c175f1) with direct DB
# writes from the projection server to projections_runs — no HTTP +
# auth needed.
